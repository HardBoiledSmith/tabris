{
  "mcpServers": {
    "op-nerv-mcp": {
      "type": "http",
      "url": "https://op-nerv.hbsmith.io/mcp",
      "headers": {
        "Authorization": "Bearer ${NERV_MCP_TOKEN}"
      }
    },
    "atlassian-rovo-mcp": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "headers": {
        "Authorization": "Basic ${ATLASSIAN_ROVO_MCP_TOKEN}"
      }
    }
  }
}
